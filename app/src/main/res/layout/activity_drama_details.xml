<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">


        <ImageView
            android:id="@+id/posterImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/poster1"/>


        <TextView
            android:id="@+id/detailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Drama Name"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/detailsTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/detailsVenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Venue"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABOUT SHOW"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/detailsDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textSize="18sp"
            android:textColor="#DDDDDD"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CAST"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/castText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cast"
            android:textSize="18sp"
            android:textColor="#DDDDDD"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/bookTicketsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BOOK TICKETS"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"
            android:backgroundTint="#FFD700"
            android:layout_marginTop="40dp"/>
        <Button
            android:id="@+id/castBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VIEW CAST and CREW"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#000000"
            android:backgroundTint="#FFD700"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>